{
  "name": "rtk-inspector",
  "displayName": "RTK Inspector",
  "description": "Visualizes token savings and command stats from rtk CLI.",
  "version": "0.1.0",
  "publisher": "PeterMEFrandsen",
  "repository": {
    "type": "git",
    "url": "https://github.com/petermefrandsen/rtk-inspector"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "resources/rtk-inspector.png",
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rtk-inspector-sidebar",
          "title": "RTK Inspector",
          "icon": "resources/rtk-inspector.png"
        }
      ],
      "panel": [
        {
          "id": "rtk-inspector-summary-panel",
          "title": "RTK Summary",
          "icon": "resources/rtk-inspector.png"
        }
      ]
    },
    "views": {
      "rtk-inspector-sidebar": [
        {
          "type": "webview",
          "id": "rtk-inspector-charts",
          "name": "RTK Stats Charts"
        }
      ],
      "rtk-inspector-summary-panel": [
        {
          "type": "webview",
          "id": "rtk-inspector-summary",
          "name": "RTK Summary"
        }
      ]
    },
    "commands": [
      {
        "command": "rtk-inspector.refresh",
        "title": "Refresh RTK Stats",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "rtk-inspector.refresh",
          "when": "view == rtk-inspector-charts",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "tsc -p ./",
    "watch": "npm-run-all -p watch:*",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "check-types": "tsc --noEmit",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && node esbuild.js --production",
    "test:coverage": "vscode-test --coverage --coverage-output ./coverage --coverage-reporter text --coverage-reporter lcov --coverage-reporter cobertura",
    "test:e2e": "extest run-tests ./out/test/e2e/*.test.js test-workspace",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.57.1",
    "typescript": "^5.3.3",
    "@playwright/test": "^1.58.2",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "proxyquire": "^2.1.3",
    "vscode-extension-tester": "^8.22.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  }
}
